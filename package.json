{
  "name": "woodiz",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "start": "NODE_ENV=production node server.js",
    "start:next": "next start -p 3000",
    "lint": "next lint",
    "backup": "node scripts/backup.js",
    "init-db": "mysql -h $MYSQL_HOST -u $MYSQL_USER -p$MYSQL_PASSWORD $MYSQL_DATABASE < lib/schema.sql",
    "hash-password": "node -e \"const b=require('bcryptjs');b.hash(process.argv[1],12).then(h=>console.log('Hash:',h))\" --"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.468.0",
    "mysql2": "^3.19.1",
    "nanoid": "^5.1.6",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}