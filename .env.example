# ============================================================
# WOODIZ PARIS — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# ⚠️  Ne jamais commiter .env.local dans Git !
# ============================================================


# ── BASE DE DONNÉES MYSQL (Hostinger) ───────────────────────
# Sur Hostinger, le host MySQL est toujours "localhost".
# Créer la base via hPanel → Bases de données → MySQL.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=u123456789_woodiz
MYSQL_PASSWORD=VotreMotDePasseMySQL
MYSQL_DATABASE=u123456789_woodiz


# ── STOCKAGE IMAGES (local Hostinger) ──────────────────────
# Les images sont stockées directement sur Hostinger dans :
#   public/uploads/products/  → produits
#   public/uploads/slider/    → slider hero
#   public/uploads/promos/    → promos
#   public/uploads/categories/→ icônes catégories
#   public/uploads/misc/      → autres
#
# Accessibles via : https://monsite.com/uploads/products/42.webp
# Aucune configuration requise — fonctionne directement sur Hostinger.
#
# Pour des images plus lourdes ou un CDN, vous pouvez configurer
# Cloudflare R2 ou Backblaze B2 ultérieurement.


# ── SITE PUBLIC ─────────────────────────────────────────────
# URL de production sans slash final.

NEXT_PUBLIC_SITE_URL=https://woodiz.fr

# Code de vérification Google Search Console
# Obtenir depuis search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=votre_code_google_verification

# Image hero préchargée (LCP) — URL de votre image principale du slider.
# Laisser vide pour désactiver le preload.
NEXT_PUBLIC_HERO_IMAGE=https://f003.backblazeb2.com/file/woodizparis/hero.webp


# ── SÉCURITÉ ────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 caractères aléatoires.

NEXTAUTH_SECRET=une_chaine_aleatoire_tres_longue_32_chars_minimum


# ── RUNTIME ─────────────────────────────────────────────────
# Sur Hostinger, toujours "production".
# En local, "development" active le hot-reload Next.js.

NODE_ENV=production
PORT=3000


# ── SSL MySQL (optionnel) ────────────────────────────────────
# Sur Hostinger, laissez vide (MySQL local ne nécessite pas SSL).
# Mettez "true" uniquement pour une connexion MySQL sur serveur distant.
# MYSQL_SSL=false

# ── HASH DU MOT DE PASSE ADMIN ───────────────────────────────
# Après déploiement, changez le mot de passe par défaut "woodiz2024" :
#   1. npm run hash-password VotreNouveauMotDePasse
#   2. Exécutez dans MySQL : UPDATE admin_credentials SET password_hash='<hash>' WHERE id=1;
# Le système migre automatiquement les mots de passe en clair vers bcrypt à la première connexion.


# ── DÉPLOIEMENT HOSTINGER — CHECKLIST ───────────────────────────────────────
# 1. Créer la base MySQL dans hPanel → Bases de données → MySQL
#    Remplir MYSQL_HOST=localhost, MYSQL_USER, MYSQL_PASSWORD, MYSQL_DATABASE
#
# 2. Initialiser le schéma :
#    mysql -u <user> -p <database> < lib/schema.sql
#    (ou via phpMyAdmin dans hPanel)
#
# 3. Créer le bucket Backblaze B2 et remplir les variables B2_*
#    (https://www.backblaze.com/b2/docs/s3_compatible_api.html)
#
# 4. Démarrer l'application :
#    npm install
#    npm run build
#    pm2 start ecosystem.config.js --env production
#    pm2 save && pm2 startup
#
# 5. Changer le mot de passe admin par défaut (woodiz2024) :
#    npm run hash-password VotreNouveauMotDePasse
#    mysql -u <user> -p <database> -e "UPDATE admin_credentials SET password_hash='<hash>' WHERE id=1;"
